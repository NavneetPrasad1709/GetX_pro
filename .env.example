# GETX environment variables (template). Copy to `.env` and fill real values.
# `.env` is gitignored. Prisma AND Next.js both read `.env`.

# ---- Database (Neon) — Step 02 ----
DATABASE_URL=
DIRECT_URL=

# ---- App ----
NEXT_PUBLIC_APP_URL=
# Auth.js session encryption secret. Generate: npx auth secret (or openssl rand -base64 32)
AUTH_SECRET=

# ---- Bot protection (Step 03) — Cloudflare Turnstile ----
# Get keys: Cloudflare dashboard → Turnstile → Add site.
# Default is ON (fail closed). For local dev WITHOUT keys, set TURNSTILE_DEV_BYPASS=true
# (ignored in production — never ship a bypass).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_DEV_BYPASS=false

# ---- Social login (Step 03) — each provider stays OFF until both its keys are set ----
# Google: https://console.cloud.google.com/apis/credentials → OAuth client ID (Web)
#   Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Discord: https://discord.com/developers/applications → New Application → OAuth2
#   Redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Payments (Step 09) ----
# CoinGate (crypto). USE SANDBOX FIRST: sign up at https://sandbox.coingate.com
# (separate from the live dashboard), then API management → create token.
#   COINGATE_ENVIRONMENT: "sandbox" while testing, "live" only at launch.
#   No separate webhook secret — CoinGate v2 callbacks are verified by a
#   per-order token we generate + re-fetching the order from the API.
COINGATE_API_KEY=
COINGATE_ENVIRONMENT=sandbox
# Razorpay (UPI/INR). Dashboard → Settings → API Keys (use TEST mode keys first).
# RAZORPAY_WEBHOOK_SECRET: YOU choose this string — generate something random,
# put it here AND paste the same value in Razorpay dashboard → Account &
# Settings → Webhooks when creating the webhook (it is NOT the key secret).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Sentry (Step 09) ----
# DSN: sentry.io → Project → Settings → Client Keys (DSN). Put the SAME value
# in both vars (NEXT_PUBLIC_ for the browser; DSNs are safe to expose).
# Leave empty to fully disable Sentry (local dev default).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional, BUILD-time only (readable stack traces via source-map upload):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ---- Cron (Step 10) - escrow auto-release ----
# Vercel attaches `Authorization: Bearer ${CRON_SECRET}` to cron requests; the
# /api/cron/auto-release route fails closed if unset. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ---- Realtime chat (Step 11) - Socket.io server (deploys to Railway) ----
# PUBLIC URL the browser connects to. Local dev = the socket server's port;
# prod = the Railway service URL (e.g. https://chat.getx.live).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Two shared secrets — set the SAME values in socket-server/.env. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SOCKET_AUTH_SECRET=
INTERNAL_API_SECRET=
# Railway socket server base URL (e.g. https://getx-socket.up.railway.app)
SOCKET_INTERNAL_URL=

# ---- Uploads (Step 12) - Cloudflare R2 (S3-compatible) ----
# Cloudflare dashboard → R2 → "Manage R2 API Tokens" (Account ID + an API token
# = Access Key ID + Secret). Create TWO buckets: one PUBLIC (listing images),
# one PRIVATE (KYC docs). Enable a public domain on the PUBLIC bucket only.
# Leave empty to disable uploads (the presign route returns 503 cleanly).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=
R2_PRIVATE_BUCKET=
# Public base URL of the PUBLIC bucket (R2.dev domain or a custom domain), no
# trailing slash, e.g. https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=

# ---- Email (Step 22) — Resend ----
# https://resend.com → API Keys → Create. Verify your sending domain first
# (Domains → Add → add the DNS records) so mail doesn't land in spam.
# Leave RESEND_API_KEY empty to DISABLE email — in-app + socket notifications
# still work; emails are skipped (logged in dev) until a key is set.
RESEND_API_KEY=
# The "from" address. Must be on a domain you verified in Resend.
RESEND_FROM_EMAIL=GETX <notifications@getx.live>

# ---- Auto-delivery (Step 19) — item content encryption ----
# 32-byte hex key for AES-256-GCM encryption of pre-loaded delivery items.
# Generate: openssl rand -hex 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Empty/malformed = auto-delivery DISABLED (seller upload hidden; INSTANT orders fall back to MANUAL).
# ROTATION needs re-encrypting all DeliveryItem.content rows (maintenance window) — see DECISIONS.md.
DELIVERY_ENCRYPTION_KEY=

# ---- AI layer (Prompt 23) — Claude API ----
# https://platform.claude.com → API Keys. Powers the AI layer (src/lib/ai.ts):
# AI support, NL→filters, listing drafts, pricing, the Dispute Judge.
# Leave empty to DISABLE all AI features — they degrade gracefully (return
# null / fallback), nothing crashes. Models per CLAUDE.md §3 are chosen in code.
ANTHROPIC_API_KEY=

# ---- AI Support widget (Step 16) ----
# Feature flag for the floating support chat. Set to "true" to show the widget.
# Even when "true", the widget hides itself if ANTHROPIC_API_KEY is empty (the
# API returns 503). NEXT_PUBLIC_ = exposed to the browser (it only gates UI).
NEXT_PUBLIC_SUPPORT_ENABLED=true

# ---- Sumsub automated KYC (Step 29) ----
# Optional. Empty = automated KYC disabled → sellers use the Step 12 manual ID upload (admin review).
# Provision at sumsub.com; SECRET_KEY signs every REST call + verifies webhooks. SERVER-ONLY.
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com

# ---- Algolia search (Step 28) ----
# Optional. Empty = search falls back to Postgres (zero-config). Provision an app at
# algolia.com, then run `npx tsx src/scripts/algolia-setup-index.ts` once per env to
# configure the index. ADMIN_KEY is SERVER-ONLY — never expose it to the browser.
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_APP_ID=        # public alias of ALGOLIA_APP_ID for client-side init
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=    # search-only key, safe to ship to the browser

# ---- PostHog product analytics (Step 31) ----
# Optional. Empty = analytics disabled (no provider, all events no-op). Privacy: only IDs + amounts
# are sent as event properties, never PII; IP is stripped. Sentry vars are in the Step 09 section.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Distributed rate limiting (Step 32) — Upstash Redis (REST) ----
# Optional. Empty = the auth/payment limiters fall back to the in-memory limiter
# (per-instance; still stops naive brute force). Set BOTH at launch for a GLOBAL
# limit shared across every serverless instance. Provision a free DB at
# https://upstash.com → Redis → REST API → copy the URL + token. SERVER-ONLY.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Webhook IP allowlists (Step 32) ----
# Optional. Empty = IP check OFF (open by default — signature/token check still
# applies). Set to the provider's published webhook source IPs (comma-separated)
# at launch for defense-in-depth. CAVEAT: behind a proxy that rewrites the source
# IP (Cloudflare orange-cloud), use DNS-only on these routes or allowlist the
# proxy egress IPs instead. See docs/DECISIONS.md (Step 32).
RAZORPAY_WEBHOOK_IPS=
COINGATE_WEBHOOK_IPS=

# ---- Test database (Step 34) ----
# Optional. Empty = the money-path INTEGRATION tests skip themselves (unit + E2E
# still run). Point it at a DISPOSABLE database (a Neon branch or a local/CI
# Postgres) — NEVER dev or prod, the tests create + delete real rows. CI uses an
# ephemeral Postgres service container. vitest.setup.ts aliases this into
# DATABASE_URL for the integration suite only.
TEST_DATABASE_URL=

# ---- CSP nonce mode (Step 32) ----
# Optional, default OFF. A strong STATIC Content-Security-Policy ships on every
# route regardless. Set to "true" to ALSO upgrade sensitive routes (auth + the
# authenticated app) to a per-request nonce + 'strict-dynamic' (stricter XSS
# protection). Verify checkout (Razorpay) + OAuth login work with it on before
# enabling in prod — it blocks un-nonced inline scripts on those routes.
CSP_NONCE_ENABLED=false
