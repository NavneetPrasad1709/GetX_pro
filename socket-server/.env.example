# GETX Socket.io server (Step 11) — standalone service, deploys to Railway.
# Copy to .env for local dev. NEVER commit the real .env.

# Port the socket server listens on (Railway injects its own PORT in prod).
PORT=4000

# The storefront origin allowed to connect (CORS). Local dev = the Next app.
# In prod set this to your real storefront origin, e.g. https://getx.live
ALLOWED_ORIGIN=http://localhost:3000

# Base URL of the GETX Next app — the socket server calls its secured internal
# API here to authorize joins + persist messages. Prod = your Vercel URL.
APP_URL=http://localhost:3000

# Shared secret used to VERIFY the short-lived socket JWT the Next app mints.
# MUST equal SOCKET_AUTH_SECRET in the Next app's .env.
SOCKET_AUTH_SECRET=

# Shared secret for server-to-server calls to the Next internal API.
# MUST equal INTERNAL_API_SECRET in the Next app's .env.
INTERNAL_API_SECRET=
